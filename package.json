{
  "name": "shinracer",
  "version": "1.0.0",
  "description": "ShinRacer — Race. Drift. Coordinate.",
  "main": "src/main/main.js",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n VITE,ELECTRON -c cyan,yellow \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "build": "vite build && electron-builder",
    "pack": "vite build && electron-builder --dir",
    "release": "vite build && electron-builder --publish always",
    "release:dry": "vite build && electron-builder --publish never",
    "lint": "eslint src/renderer"
  },
  "build": {
    "appId": "com.shintech.shinracer",
    "productName": "ShinRacer",
    "copyright": "ShinTech Electronics",
    "publish": {
      "provider": "github",
      "owner": "ShinobiFPV",
      "repo": "ShinRacer",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "requireAdministrator",
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "shortcutName": "ShinRacer"
    },
    "extraResources": [
      {
        "from": "backend/",
        "to": "backend/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "resources/**/*"
    ]
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.9",
    "qrcode-generator": "^2.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
