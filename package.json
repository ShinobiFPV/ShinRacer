{
  "name": "ac-server-manager",
  "version": "1.0.0",
  "description": "Assetto Corsa Server Manager — ShinTech Edition",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently -n VITE,ELECTRON -c cyan,yellow \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "build": "vite build && electron-builder",
    "pack": "vite build && electron-builder --dir",
    "lint": "eslint src/renderer"
  },
  "build": {
    "appId": "com.shintech.ac-server-manager",
    "productName": "AC Server Manager",
    "copyright": "ShinTech Electronics",
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "requestedExecutionLevel": "requireAdministrator",
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "shortcutName": "AC Server Manager"
    },
    "extraResources": [
      { "from": "backend/", "to": "backend/", "filter": ["**/*"] }
    ],
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "resources/**/*"
    ]
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
