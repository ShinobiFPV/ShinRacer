VITE_BACKEND_URL=http://192.168.1.203:3000

# Mod Manager — Google Drive integration (backend/.env on shinobi, not bundled in the app)
GOOGLE_SERVICE_ACCOUNT_PATH=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_CARS_FOLDER_ID=
GOOGLE_DRIVE_TRACKS_FOLDER_ID=
GOOGLE_DRIVE_TOOLS_FOLDER_ID=
GOOGLE_DRIVE_UPLOADS_FOLDER_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:9721

# Companion PWA (Phase 10) — served by nginx on shinobi, backend/.env only
GOOGLE_OAUTH_REDIRECT_URI_PWA=http://192.168.1.203:8080/auth/callback
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:shinobi@shintech.local

# Car Stereo (Phase 18) — Spotify Web Playback SDK + Web API, backend/.env only.
# Create a free app at developer.spotify.com/dashboard and add the redirect
# URI below exactly. Client secret never leaves the backend — see
# backend/routes/stereo.js and docs/CAR_STEREO_SETUP.md.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:9722
