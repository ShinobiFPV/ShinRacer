# Android TWA — signing keystore and its password are a permanent secret,
# never committed. The project scaffold (twa-manifest.json, app/, gradle
# files) IS committed so `bubblewrap build` is reproducible from source.
android-twa/android.keystore
android-twa/.keystore-credentials.txt
android-twa/app-release-signed.apk
android-twa/app-release-bundle.aab
android-twa/*.apk
android-twa/*.aab
android-twa/*.idsig
android-twa/.gradle/
android-twa/app/build/
android-twa/build/

